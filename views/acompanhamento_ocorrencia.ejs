<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>Acompanhamento da Ocorrência</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-layout">
    <%- include('partials/sidebar') %>

    <main class="main-content">
      <%- include('partials/header', { titulo: 'Acompanhamento da Ocorrência' }) %>

      <div class="acompanhar-page">
        <section class="nova-card destaque">
          <div class="nova-card-header">
            <div>
              <h3>Ocorrência #<%= ocorrencia.numero %></h3>
              <p><strong>Status:</strong> <%= ocorrencia.status_nome || ocorrencia.status || 'Aberto' %></p>
            </div>
            <div class="numero-badge">
              <span>Responsável</span>
              <strong><%= ocorrencia.responsavel_nome || '-' %></strong>
            </div>
          </div>

          <div class="acompanhar-resumo">
            <div class="resumo-pill">
              <span>Cliente</span>
              <strong><%= ocorrencia.razao_social || ocorrencia.cliente || '-' %></strong>
            </div>
            <div class="resumo-pill">
              <span>Origem</span>
              <strong><%= ocorrencia.origem_erro || '-' %></strong>
            </div>
            <div class="resumo-pill">
              <span>Faturado por</span>
              <strong><%= ocorrencia.faturado_por || '-' %></strong>
            </div>
            <div class="resumo-pill">
              <span>Data</span>
              <strong><%= ocorrencia.criado_em ? new Date(ocorrencia.criado_em).toLocaleString('pt-BR') : '-' %></strong>
            </div>
          </div>
        </section>

        <% if (erro) { %>
          <div class="alert-error"><%= erro %></div>
        <% } %>

        <% if (sucesso) { %>
          <div class="alert-success"><%= sucesso %></div>
        <% } %>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Atualizar ocorrência</h3>
          </div>

          <form method="POST" action="/ocorrencias/<%= ocorrencia.id %>/atualizar">
            <div class="nova-grid-2">
              <div>
                <label for="novo_status">Novo status</label>
                <select id="novo_status" name="novo_status">
                  <option value="">Manter status atual</option>
                  <% statusList.forEach(status => { %>
                    <option value="<%= status.nome %>"><%= status.nome %></option>
                  <% }) %>
                </select>
              </div>

              <div></div>
            </div>

            <div class="top-gap">
              <label for="comentario">Comentário / andamento *</label>
              <textarea id="comentario" name="comentario" rows="5" required></textarea>
            </div>

            <div class="acoes-form top-gap">
              <button type="submit" class="btn-primary">Registrar atualização</button>
            </div>
          </form>
        </section>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Dados principais</h3>
          </div>

          <div class="nova-grid-2">
            <div>
              <label>Razão Social</label>
              <input type="text" value="<%= ocorrencia.razao_social || '' %>" disabled>
            </div>
            <div>
              <label>CNPJ</label>
              <input type="text" value="<%= ocorrencia.cnpj || '' %>" disabled>
            </div>
            <div>
              <label>Número do Pedido</label>
              <input type="text" value="<%= ocorrencia.numero_pedido || '' %>" disabled>
            </div>
            <div>
              <label>Número da NF</label>
              <input type="text" value="<%= ocorrencia.numero_nf || '' %>" disabled>
            </div>
            <div>
              <label>NFD emitida?</label>
              <input type="text" value="<%= ocorrencia.tem_nfd === true ? 'Sim' : 'Não' %>" disabled>
            </div>
            <div>
              <label>Número da NFD</label>
              <input type="text" value="<%= ocorrencia.numero_nfd || '' %>" disabled>
            </div>
            <div>
              <label>Responsável</label>
              <input type="text" value="<%= ocorrencia.responsavel_nome || '' %>" disabled>
            </div>
            <div>
              <label>Criado por</label>
              <input type="text" value="<%= ocorrencia.criado_por_nome || '' %>" disabled>
            </div>
          </div>
        </section>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Título / Assunto</h3>
          </div>
          <input type="text" value="<%= ocorrencia.titulo || '' %>" disabled>
        </section>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Descrição</h3>
          </div>
          <textarea class="descricao-grande" disabled><%= ocorrencia.descricao || '' %></textarea>
        </section>

        <% if (questionario) { %>
          <section class="nova-card">
            <div class="nova-section-title">
              <h3>Questionário preenchido</h3>
            </div>

            <div class="nova-grid-2">
              <div>
                <label>Faltou volume?</label>
                <input type="text" value="<%= questionario.faltou_volume === true ? 'Sim' : questionario.faltou_volume === false ? 'Não' : '' %>" disabled>
              </div>
              <div>
                <label>Quantidade de volumes faltantes</label>
                <input type="text" value="<%= questionario.quantidade_volumes_faltantes || '' %>" disabled>
              </div>
              <div>
                <label>Volume saiu correto da Fábrica?</label>
                <input type="text" value="<%= questionario.volume_saiu_correto_fabrica === true ? 'Sim' : questionario.volume_saiu_correto_fabrica === false ? 'Não' : '' %>" disabled>
              </div>
              <div>
                <label>Volume saiu correto da Transmac?</label>
                <input type="text" value="<%= questionario.volume_saiu_correto_transmac === true ? 'Sim' : questionario.volume_saiu_correto_transmac === false ? 'Não' : '' %>" disabled>
              </div>
              <div>
                <label>Faltou item?</label>
                <input type="text" value="<%= questionario.faltou_item === true ? 'Sim' : questionario.faltou_item === false ? 'Não' : '' %>" disabled>
              </div>
              <div>
                <label>Sobrou item?</label>
                <input type="text" value="<%= questionario.sobrou_item === true ? 'Sim' : questionario.sobrou_item === false ? 'Não' : '' %>" disabled>
              </div>
            </div>
          </section>
        <% } %>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Itens</h3>
          </div>

          <% if (itens.length === 0) { %>
            <div class="empty-box">Nenhum item registrado.</div>
          <% } %>

          <% if (itensPorBloco.transportadora_faltou.length) { %>
            <div class="subcard itens-subcard">
              <h4>Transportadora - Itens que faltaram</h4>
              <div class="table-wrap top-gap">
                <table class="tabela-ocorrencias">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Produto</th>
                      <th>Empresa</th>
                      <th>Quantidade</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% itensPorBloco.transportadora_faltou.forEach(item => { %>
                      <tr>
                        <td><%= item.codigo_produto || '' %></td>
                        <td><%= item.nome_produto || '' %></td>
                        <td><%= item.empresa || '' %></td>
                        <td><%= item.quantidade || '' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>

          <% if (itensPorBloco.transportadora_sobrou.length) { %>
            <div class="subcard itens-subcard">
              <h4>Transportadora - Itens que sobraram</h4>
              <div class="table-wrap top-gap">
                <table class="tabela-ocorrencias">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Produto</th>
                      <th>Empresa</th>
                      <th>Quantidade</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% itensPorBloco.transportadora_sobrou.forEach(item => { %>
                      <tr>
                        <td><%= item.codigo_produto || '' %></td>
                        <td><%= item.nome_produto || '' %></td>
                        <td><%= item.empresa || '' %></td>
                        <td><%= item.quantidade || '' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>

          <% if (itensPorBloco.fabrica_faltou.length) { %>
            <div class="subcard itens-subcard">
              <h4>Fábrica - Itens que faltaram</h4>
              <div class="table-wrap top-gap">
                <table class="tabela-ocorrencias">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Produto</th>
                      <th>Empresa</th>
                      <th>Quantidade</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% itensPorBloco.fabrica_faltou.forEach(item => { %>
                      <tr>
                        <td><%= item.codigo_produto || '' %></td>
                        <td><%= item.nome_produto || '' %></td>
                        <td><%= item.empresa || '' %></td>
                        <td><%= item.quantidade || '' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>

          <% if (itensPorBloco.fabrica_sobrou.length) { %>
            <div class="subcard itens-subcard">
              <h4>Fábrica - Itens que sobraram</h4>
              <div class="table-wrap top-gap">
                <table class="tabela-ocorrencias">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Produto</th>
                      <th>Empresa</th>
                      <th>Quantidade</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% itensPorBloco.fabrica_sobrou.forEach(item => { %>
                      <tr>
                        <td><%= item.codigo_produto || '' %></td>
                        <td><%= item.nome_produto || '' %></td>
                        <td><%= item.empresa || '' %></td>
                        <td><%= item.quantidade || '' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>

          <% if (itensPorBloco.outros.length) { %>
            <div class="subcard itens-subcard">
              <h4>Outros itens</h4>
              <div class="table-wrap top-gap">
                <table class="tabela-ocorrencias">
                  <thead>
                    <tr>
                      <th>Código</th>
                      <th>Produto</th>
                      <th>Empresa</th>
                      <th>Quantidade</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% itensPorBloco.outros.forEach(item => { %>
                      <tr>
                        <td><%= item.codigo_produto || '' %></td>
                        <td><%= item.nome_produto || '' %></td>
                        <td><%= item.empresa || '' %></td>
                        <td><%= item.quantidade || '' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% } %>
        </section>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Anexos</h3>
          </div>

          <% if (anexos.length === 0) { %>
            <div class="empty-box">Nenhum anexo registrado.</div>
          <% } else { %>
            <div class="anexos-lista">
              <% anexos.forEach(anexo => { %>
                <a class="anexo-card" href="<%= anexo.url_arquivo %>" target="_blank">
                  <div class="anexo-titulo"><%= anexo.nome_original %></div>
                  <div class="anexo-meta">
                    <span><%= anexo.tamanho_bytes ? Math.round(anexo.tamanho_bytes / 1024) : 0 %> KB</span>
                    <span><%= anexo.enviado_em ? new Date(anexo.enviado_em).toLocaleString('pt-BR') : '' %></span>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } %>
        </section>

        <section class="nova-card">
          <div class="nova-section-title">
            <h3>Histórico</h3>
          </div>

          <% if (historico.length === 0) { %>
            <div class="empty-box">Nenhum histórico registrado.</div>
          <% } else { %>
            <div class="timeline">
              <% historico.forEach(item => { %>
                <div class="timeline-item">
                  <div class="timeline-dot"></div>
                  <div class="timeline-content">
                    <div class="timeline-topo">
                      <strong><%= item.titulo_evento || item.acao || 'Evento' %></strong>
                      <span><%= item.criado_em ? new Date(item.criado_em).toLocaleString('pt-BR') : '' %></span>
                    </div>
                    <div class="timeline-meta">
                      <%= item.usuario_nome || 'Sistema' %>
                    </div>
                    <div class="timeline-texto">
                      <%= item.descricao_evento || item.acao || '' %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>
      </div>
    </main>
  </div>

  <%- include('partials/scripts') %>
</body>
</html>
