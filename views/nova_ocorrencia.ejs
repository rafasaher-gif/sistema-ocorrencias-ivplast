<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>Nova Ocorrência</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-layout">
    <%- include('partials/sidebar') %>

    <main class="main-content">
      <%- include('partials/header', { titulo: 'Nova Ocorrência' }) %>

      <div class="nova-page">
        <form id="formNovaOcorrencia" class="nova-form">
          <input type="hidden" id="itens_json" name="itens_json">

          <section class="nova-card destaque">
            <div class="nova-card-header">
              <div>
                <h3>Abertura da ocorrência</h3>
                <p>Preencha os dados do caso conforme a origem do erro.</p>
              </div>
              <div class="numero-badge">
                <span>Nº da ocorrência</span>
                <strong><%= proximoNumero %></strong>
              </div>
            </div>

            <div class="nova-grid-2">
              <div>
                <label>Número da ocorrência</label>
                <input type="text" value="<%= proximoNumero %>" disabled>
              </div>
              <div>
                <label>Status inicial</label>
                <input type="text" value="Aberto" disabled>
              </div>
            </div>
          </section>

          <section class="nova-card">
            <div class="nova-section-title">
              <h3>Cliente</h3>
            </div>

            <div class="nova-grid-2">
              <div>
                <label for="razao_social">Razão Social *</label>
                <input type="text" id="razao_social" name="razao_social" required>
              </div>

              <div>
                <label for="cnpj">CNPJ *</label>
                <input type="text" id="cnpj" name="cnpj" maxlength="18" placeholder="00.000.000/0000-00" required>
              </div>

              <div>
                <label for="numero_pedido">Número do Pedido *</label>
                <input type="text" id="numero_pedido" name="numero_pedido" required>
              </div>

              <div>
                <label for="numero_nf">Número da NF *</label>
                <input type="text" id="numero_nf" name="numero_nf" required>
              </div>
            </div>
          </section>

          <section class="nova-card">
            <div class="nova-section-title">
              <h3>NFD</h3>
            </div>

            <div class="nova-grid-2">
              <div>
                <label>Cliente já emitiu NFD? *</label>
                <div class="radio-group">
                  <label class="radio-option">
                    <input type="radio" name="tem_nfd" value="false" checked>
                    <span>Não</span>
                  </label>

                  <label class="radio-option">
                    <input type="radio" name="tem_nfd" value="true">
                    <span>Sim</span>
                  </label>
                </div>
              </div>

              <div>
                <label for="numero_nfd">Número da NFD *</label>
                <input type="text" id="numero_nfd" name="numero_nfd" disabled>
                <small class="campo-ajuda">Este campo só habilita quando marcar “Sim”.</small>
              </div>
            </div>
          </section>

          <section class="nova-card">
            <div class="nova-section-title">
              <h3>Classificação</h3>
            </div>

            <div class="nova-grid-2">
              <div>
                <label for="faturado_por">Faturado por *</label>
                <select id="faturado_por" name="faturado_por" required>
                  <option value="">Selecione...</option>
                  <option value="IVPLAST">IVPLAST</option>
                  <option value="VENANI">VENANI</option>
                </select>
                <small class="campo-ajuda">A lista de itens muda conforme esta seleção.</small>
              </div>

              <div>
                <label for="responsavel_usuario_id">Responsável *</label>
                <select id="responsavel_usuario_id" name="responsavel_usuario_id" required>
                  <option value="">Selecione...</option>
                  <% usuarios.forEach(usuario => { %>
                    <option value="<%= usuario.id %>"><%= usuario.nome %> - <%= usuario.perfil %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label for="origem_erro">Origem do erro *</label>
                <select id="origem_erro" name="origem_erro" required>
                  <option value="">Selecione...</option>
                  <option value="Transportadora">Transportadora</option>
                  <option value="Fábrica">Fábrica</option>
                  <option value="Cliente">Cliente</option>
                  <option value="Vendedor">Vendedor</option>
                  <option value="Outro">Outro</option>
                </select>
              </div>

              <div>
                <label for="titulo">Título / Assunto *</label>
                <input type="text" id="titulo" name="titulo" placeholder="Ex.: Faltou 3 pacotes / Divergência de itens" required>
              </div>
            </div>
          </section>

          <section class="nova-card hidden" id="cardQuestionario">
            <div class="nova-section-title">
              <h3>Questionário dinâmico</h3>
            </div>

            <div id="questionarioTransportadora" class="hidden">
              <div class="subcard">
                <h4>Transportadora</h4>

                <div class="nova-grid-2">
                  <div>
                    <label>Faltou algum volume?</label>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="faltou_volume" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="faltou_volume" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>

                  <div>
                    <label for="quantidade_volumes_faltantes">Quantidade de volumes faltantes</label>
                    <input type="number" id="quantidade_volumes_faltantes" name="quantidade_volumes_faltantes" min="1" disabled>
                  </div>

                  <div>
                    <label>Volume saiu correto da Fábrica?</label>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="volume_saiu_correto_fabrica" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="volume_saiu_correto_fabrica" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>

                  <div>
                    <label>Volume saiu correto da Transmac?</label>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="volume_saiu_correto_transmac" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="volume_saiu_correto_transmac" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>
                </div>

                <div id="alertaTransportadora" class="alerta-sistema hidden">
                  Se o volume saiu correto da Fábrica e da Transmac, orientar verificação com a transportadora do cliente.
                </div>

                <div class="subcard itens-subcard">
                  <div class="subcard-header">
                    <h4>Itens que faltaram</h4>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="t_faltou_item" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="t_faltou_item" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>

                  <div id="wrap_t_faltou" class="hidden">
                    <div class="item-builder">
                      <div class="autocomplete-wrap">
                        <label>Produto</label>
                        <input type="text" id="busca_t_faltou" placeholder="Digite código ou nome do produto">
                        <div class="autocomplete-list" id="lista_t_faltou"></div>
                      </div>

                      <div>
                        <label>Código</label>
                        <input type="text" id="codigo_t_faltou" disabled>
                      </div>

                      <div>
                        <label>Produto selecionado</label>
                        <input type="text" id="nome_t_faltou" disabled>
                      </div>

                      <div>
                        <label>Quantidade</label>
                        <input type="number" id="quantidade_t_faltou" min="1">
                      </div>

                      <div class="alinha-bottom">
                        <button type="button" class="btn-primary btn-inline" id="btnAddTFaltou">Adicionar item</button>
                      </div>
                    </div>

                    <div class="table-wrap top-gap">
                      <table class="tabela-ocorrencias">
                        <thead>
                          <tr>
                            <th>Código</th>
                            <th>Produto</th>
                            <th>Empresa</th>
                            <th>Quantidade</th>
                            <th>Ação</th>
                          </tr>
                        </thead>
                        <tbody id="tbody_t_faltou">
                          <tr><td colspan="5">Nenhum item adicionado.</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>

                <div class="subcard itens-subcard">
                  <div class="subcard-header">
                    <h4>Itens que sobraram</h4>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="t_sobrou_item" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="t_sobrou_item" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>

                  <div id="wrap_t_sobrou" class="hidden">
                    <div class="item-builder">
                      <div class="autocomplete-wrap">
                        <label>Produto</label>
                        <input type="text" id="busca_t_sobrou" placeholder="Digite código ou nome do produto">
                        <div class="autocomplete-list" id="lista_t_sobrou"></div>
                      </div>

                      <div>
                        <label>Código</label>
                        <input type="text" id="codigo_t_sobrou" disabled>
                      </div>

                      <div>
                        <label>Produto selecionado</label>
                        <input type="text" id="nome_t_sobrou" disabled>
                      </div>

                      <div>
                        <label>Quantidade</label>
                        <input type="number" id="quantidade_t_sobrou" min="1">
                      </div>

                      <div class="alinha-bottom">
                        <button type="button" class="btn-primary btn-inline" id="btnAddTSobrou">Adicionar item</button>
                      </div>
                    </div>

                    <div class="table-wrap top-gap">
                      <table class="tabela-ocorrencias">
                        <thead>
                          <tr>
                            <th>Código</th>
                            <th>Produto</th>
                            <th>Empresa</th>
                            <th>Quantidade</th>
                            <th>Ação</th>
                          </tr>
                        </thead>
                        <tbody id="tbody_t_sobrou">
                          <tr><td colspan="5">Nenhum item adicionado.</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div id="questionarioFabrica" class="hidden">
              <div class="subcard">
                <h4>Fábrica</h4>

                <div class="subcard itens-subcard">
                  <div class="subcard-header">
                    <h4>Itens que faltaram</h4>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="f_faltou_item" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="f_faltou_item" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>

                  <div id="wrap_f_faltou" class="hidden">
                    <div class="item-builder">
                      <div class="autocomplete-wrap">
                        <label>Produto</label>
                        <input type="text" id="busca_f_faltou" placeholder="Digite código ou nome do produto">
                        <div class="autocomplete-list" id="lista_f_faltou"></div>
                      </div>

                      <div>
                        <label>Código</label>
                        <input type="text" id="codigo_f_faltou" disabled>
                      </div>

                      <div>
                        <label>Produto selecionado</label>
                        <input type="text" id="nome_f_faltou" disabled>
                      </div>

                      <div>
                        <label>Quantidade</label>
                        <input type="number" id="quantidade_f_faltou" min="1">
                      </div>

                      <div class="alinha-bottom">
                        <button type="button" class="btn-primary btn-inline" id="btnAddFFaltou">Adicionar item</button>
                      </div>
                    </div>

                    <div class="table-wrap top-gap">
                      <table class="tabela-ocorrencias">
                        <thead>
                          <tr>
                            <th>Código</th>
                            <th>Produto</th>
                            <th>Empresa</th>
                            <th>Quantidade</th>
                            <th>Ação</th>
                          </tr>
                        </thead>
                        <tbody id="tbody_f_faltou">
                          <tr><td colspan="5">Nenhum item adicionado.</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>

                <div class="subcard itens-subcard">
                  <div class="subcard-header">
                    <h4>Itens que sobraram</h4>
                    <div class="radio-group">
                      <label class="radio-option">
                        <input type="radio" name="f_sobrou_item" value="false" checked>
                        <span>Não</span>
                      </label>
                      <label class="radio-option">
                        <input type="radio" name="f_sobrou_item" value="true">
                        <span>Sim</span>
                      </label>
                    </div>
                  </div>

                  <div id="wrap_f_sobrou" class="hidden">
                    <div class="item-builder">
                      <div class="autocomplete-wrap">
                        <label>Produto</label>
                        <input type="text" id="busca_f_sobrou" placeholder="Digite código ou nome do produto">
                        <div class="autocomplete-list" id="lista_f_sobrou"></div>
                      </div>

                      <div>
                        <label>Código</label>
                        <input type="text" id="codigo_f_sobrou" disabled>
                      </div>

                      <div>
                        <label>Produto selecionado</label>
                        <input type="text" id="nome_f_sobrou" disabled>
                      </div>

                      <div>
                        <label>Quantidade</label>
                        <input type="number" id="quantidade_f_sobrou" min="1">
                      </div>

                      <div class="alinha-bottom">
                        <button type="button" class="btn-primary btn-inline" id="btnAddFSobrou">Adicionar item</button>
                      </div>
                    </div>

                    <div class="table-wrap top-gap">
                      <table class="tabela-ocorrencias">
                        <thead>
                          <tr>
                            <th>Código</th>
                            <th>Produto</th>
                            <th>Empresa</th>
                            <th>Quantidade</th>
                            <th>Ação</th>
                          </tr>
                        </thead>
                        <tbody id="tbody_f_sobrou">
                          <tr><td colspan="5">Nenhum item adicionado.</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div id="questionarioSimples" class="hidden">
              <div class="subcard">
                <h4>Cliente / Vendedor / Outro</h4>
                <p class="campo-ajuda sem-margem">
                  Para essas origens, não há questionário detalhado nesta etapa.
                </p>
              </div>
            </div>
          </section>

          <section class="nova-card">
            <div class="nova-section-title">
              <h3>Descrição</h3>
            </div>

            <div>
              <label for="descricao">Descrição da ocorrência *</label>
              <textarea id="descricao" name="descricao" rows="6" required></textarea>
            </div>
          </section>

          <section class="nova-card">
            <div class="nova-section-title">
              <h3>Anexos</h3>
            </div>

            <div class="nova-grid-2">
              <div>
                <label for="anexos">Selecionar arquivos</label>
                <input type="file" id="anexos" name="anexos" multiple>
                <small class="campo-ajuda">A gravação real de anexos entra na próxima etapa.</small>
              </div>

              <div>
                <label>Resumo</label>
                <input type="text" value="Status inicial: Aberto" disabled>
              </div>
            </div>
          </section>

          <div class="acoes-form">
            <button type="submit" class="btn-primary">Salvar ocorrência</button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <div class="modal-overlay hidden" id="modalTransportadora">
    <div class="modal-box">
      <h3>Atenção</h3>
      <p>
        Se o volume saiu correto da Fábrica e da Transmac,
        verificar com a transportadora do cliente.
      </p>
      <button type="button" class="btn-primary btn-inline" id="btnFecharModalTransportadora">OK</button>
    </div>
  </div>

  <%- include('partials/scripts') %>
</body>
</html>
