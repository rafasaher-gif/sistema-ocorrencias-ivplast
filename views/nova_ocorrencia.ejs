<!DOCTYPE html>
<html lang="pt-br">
<head>
  <title>Nova Ocorrência</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-layout">
    <%- include('partials/sidebar') %>

    <main class="main-content">
      <%- include('partials/header', { titulo: 'Nova Ocorrência' }) %>

      <div class="nova-wrap">
        <form id="formNovaOcorrencia">
          <div class="topbar-form">
            <div>
              <div class="topbar-title">Abrir nova ocorrência</div>
              <div class="topbar-sub">Preencha os dados do caso conforme a origem do erro.</div>
            </div>
            <span class="pill"><span class="dot primary"></span> Nº <%= proximoNumero %></span>
          </div>

          <input type="hidden" id="itens_json" name="itens_json">

          <!-- 1) CLIENTE -->
          <div class="card-form">
            <div class="section-head client">
              <div>👤 Cliente</div>
              <small>Dados do cliente/pedido</small>
            </div>

            <div class="grid-2">
              <div>
                <label for="razao_social">Razão Social *</label>
                <input type="text" id="razao_social" name="razao_social" required>
              </div>

              <div>
                <label for="cnpj">CNPJ *</label>
                <input type="text" id="cnpj" name="cnpj" maxlength="18" placeholder="00.000.000/0000-00" required>
              </div>
            </div>

            <div class="grid-2">
              <div>
                <label for="numero_pedido">Número do Pedido *</label>
                <input type="text" id="numero_pedido" name="numero_pedido" required>
              </div>

              <div>
                <label for="numero_nf">Número da NF *</label>
                <input type="text" id="numero_nf" name="numero_nf" required>
              </div>
            </div>
          </div>

          <!-- 2) NFD -->
          <div class="card-form">
            <div class="section-head nfd">
              <div>🧾 NFD</div>
              <small>Sempre visível</small>
            </div>

            <div class="grid-2">
              <div>
                <label>Cliente já emitiu NFD? *</label>
                <div class="radio-row">
                  <label class="radio-box">
                    <input type="radio" name="tem_nfd" value="false" checked>
                    <strong>Não</strong>
                  </label>

                  <label class="radio-box">
                    <input type="radio" name="tem_nfd" value="true">
                    <strong>Sim</strong>
                  </label>
                </div>
              </div>

              <div>
                <label for="numero_nfd">Número da NFD *</label>
                <input type="text" id="numero_nfd" name="numero_nfd" disabled>
                <div class="field-hint">Habilita somente quando marcar “Sim”.</div>
              </div>
            </div>
          </div>

          <!-- 3) CLASSIFICAÇÃO -->
          <div class="card-form">
            <div class="section-head classif">
              <div>🏷️ Classificação</div>
              <small>Quem faturou / responsável / origem</small>
            </div>

            <div class="grid-2">
              <div>
                <label for="faturado_por">Faturado por *</label>
                <select id="faturado_por" name="faturado_por" required>
                  <option value="">Selecione...</option>
                  <option value="IVPLAST">IVPLAST</option>
                  <option value="VENANI">VENANI</option>
                </select>
                <div class="field-hint">A lista de itens muda conforme esta seleção.</div>
              </div>

              <div>
                <label for="responsavel_usuario_id">Responsável *</label>
                <select id="responsavel_usuario_id" name="responsavel_usuario_id" required>
                  <option value="">Selecione...</option>
                  <% usuarios.forEach(usuario => { %>
                    <option value="<%= usuario.id %>"><%= usuario.nome %> - <%= usuario.perfil %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="grid-2">
              <div>
                <label for="origem_erro">Origem do erro *</label>
                <select id="origem_erro" name="origem_erro" required>
                  <option value="">Selecione...</option>
                  <option value="Transportadora">Transportadora</option>
                  <option value="Fábrica">Fábrica</option>
                  <option value="Cliente">Cliente</option>
                  <option value="Vendedor">Vendedor</option>
                  <option value="Outro">Outro</option>
                </select>
              </div>

              <div>
                <label for="titulo">Título / Assunto *</label>
                <input type="text" id="titulo" name="titulo" placeholder="Ex.: Faltou 3 pacotes / Divergência de itens" required>
              </div>
            </div>
          </div>

          <!-- 4) QUESTIONÁRIO DINÂMICO -->
          <div class="card-form hidden" id="cardDynamic">
            <div class="section-head dynamic">
              <div>🧩 Questionário dinâmico</div>
              <small>Conforme a origem do erro</small>
            </div>

            <!-- TRANSPORTADORA -->
            <div id="qTransportadora" class="box-form hidden">
              <div class="box-title">
                <span>📦 Questionário — Transportadora</span>
                <span class="tag-ui">Checklist</span>
              </div>

              <div class="grid-2">
                <div>
                  <label>Faltou algum volume?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="faltou_volume" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="faltou_volume" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>

                <div>
                  <label for="quantidade_volumes_faltantes">Qtde de volumes faltantes</label>
                  <input type="number" id="quantidade_volumes_faltantes" name="quantidade_volumes_faltantes" min="0" step="1" disabled>
                </div>
              </div>

              <div class="divider-line"></div>

              <div class="grid-2">
                <div>
                  <label>Volume saiu correto da Fábrica?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="volume_saiu_correto_fabrica" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="volume_saiu_correto_fabrica" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>

                <div>
                  <label>Volume saiu correto da Transmac?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="volume_saiu_correto_transmac" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="volume_saiu_correto_transmac" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>
              </div>

              <div id="toastTransportadora" class="toast-ui hidden">
                ✅ Fábrica e Transmac deram OK.<br>
                <b>Favor conferir com a transportadora do cliente</b> se o volume faltante está com ela.
              </div>

              <div class="divider-line"></div>

              <div class="grid-2">
                <div>
                  <label>Faltou item?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="t_faltou_item" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="t_faltou_item" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>
                <div></div>
              </div>

              <div class="items-card hidden" id="tItensFaltouWrap">
                <div class="items-head">
                  <div class="left">📋 Itens que faltaram (Transportadora)</div>
                </div>

                <div class="item-builder">
                  <select id="t_faltou_produto_select">
                    <option value="">Selecione o faturado por primeiro</option>
                  </select>
                  <input type="number" id="t_faltou_quantidade" min="1" step="1" placeholder="Quantidade">
                  <button type="button" class="btn-primary btn-inline" id="btnAddTFaltou">+ Adicionar item</button>
                </div>

                <div class="table-wrap top-gap">
                  <table class="tabela-ocorrencias">
                    <thead>
                      <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Empresa</th>
                        <th>Quantidade</th>
                        <th>Ação</th>
                      </tr>
                    </thead>
                    <tbody id="tItensFaltouList">
                      <tr class="sem-itens-row">
                        <td colspan="5">Nenhum item adicionado.</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <div class="grid-2 top-gap">
                <div>
                  <label>Sobrou item?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="t_sobrou_item" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="t_sobrou_item" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>
                <div></div>
              </div>

              <div class="items-card hidden" id="tItensSobrouWrap">
                <div class="items-head">
                  <div class="left">📋 Itens que sobraram (Transportadora)</div>
                </div>

                <div class="item-builder">
                  <select id="t_sobrou_produto_select">
                    <option value="">Selecione o faturado por primeiro</option>
                  </select>
                  <input type="number" id="t_sobrou_quantidade" min="1" step="1" placeholder="Quantidade">
                  <button type="button" class="btn-primary btn-inline" id="btnAddTSobrou">+ Adicionar item</button>
                </div>

                <div class="table-wrap top-gap">
                  <table class="tabela-ocorrencias">
                    <thead>
                      <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Empresa</th>
                        <th>Quantidade</th>
                        <th>Ação</th>
                      </tr>
                    </thead>
                    <tbody id="tItensSobrouList">
                      <tr class="sem-itens-row">
                        <td colspan="5">Nenhum item adicionado.</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- FABRICA -->
            <div id="qFabrica" class="box-form hidden">
              <div class="box-title">
                <span>🏭 Questionário — Fábrica</span>
                <span class="tag-ui">Checklist</span>
              </div>

              <div class="grid-2">
                <div>
                  <label>Faltou item?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="f_faltou_item" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="f_faltou_item" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>
                <div></div>
              </div>

              <div class="items-card hidden" id="fItensFaltouWrap">
                <div class="items-head">
                  <div class="left">📋 Itens que faltaram (Fábrica)</div>
                </div>

                <div class="item-builder">
                  <select id="f_faltou_produto_select">
                    <option value="">Selecione o faturado por primeiro</option>
                  </select>
                  <input type="number" id="f_faltou_quantidade" min="1" step="1" placeholder="Quantidade">
                  <button type="button" class="btn-primary btn-inline" id="btnAddFFaltou">+ Adicionar item</button>
                </div>

                <div class="table-wrap top-gap">
                  <table class="tabela-ocorrencias">
                    <thead>
                      <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Empresa</th>
                        <th>Quantidade</th>
                        <th>Ação</th>
                      </tr>
                    </thead>
                    <tbody id="fItensFaltouList">
                      <tr class="sem-itens-row">
                        <td colspan="5">Nenhum item adicionado.</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <div class="divider-line"></div>

              <div class="grid-2">
                <div>
                  <label>Sobrou item?</label>
                  <div class="radio-row">
                    <label class="radio-box">
                      <input type="radio" name="f_sobrou_item" value="false" checked>
                      <strong>Não</strong>
                    </label>

                    <label class="radio-box">
                      <input type="radio" name="f_sobrou_item" value="true">
                      <strong>Sim</strong>
                    </label>
                  </div>
                </div>
                <div></div>
              </div>

              <div class="items-card hidden" id="fItensSobrouWrap">
                <div class="items-head">
                  <div class="left">📋 Itens que sobraram (Fábrica)</div>
                </div>

                <div class="item-builder">
                  <select id="f_sobrou_produto_select">
                    <option value="">Selecione o faturado por primeiro</option>
                  </select>
                  <input type="number" id="f_sobrou_quantidade" min="1" step="1" placeholder="Quantidade">
                  <button type="button" class="btn-primary btn-inline" id="btnAddFSobrou">+ Adicionar item</button>
                </div>

                <div class="table-wrap top-gap">
                  <table class="tabela-ocorrencias">
                    <thead>
                      <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Empresa</th>
                        <th>Quantidade</th>
                        <th>Ação</th>
                      </tr>
                    </thead>
                    <tbody id="fItensSobrouList">
                      <tr class="sem-itens-row">
                        <td colspan="5">Nenhum item adicionado.</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- CLIENTE / VENDEDOR / OUTRO -->
            <div id="qSimples" class="box-form hidden">
              <div class="box-title">
                <span>📝 Cliente / Vendedor / Outro</span>
                <span class="tag-ui">Simples</span>
              </div>

              <div class="field-hint no-margin">
                Para <b>Cliente</b>, <b>Vendedor</b> ou <b>Outro</b>: somente <b>Título / Assunto</b>, <b>Descrição</b> e <b>NFD</b>.
              </div>
            </div>
          </div>

          <!-- 5) DESCRIÇÃO -->
          <div class="card-form">
            <div class="section-head desc">
              <div>📝 Descrição do caso</div>
              <small>Antes dos anexos</small>
            </div>

            <div>
              <label for="descricao">Descrição *</label>
              <textarea id="descricao" name="descricao" rows="6" placeholder="Descreva o problema e o que precisa ser feito..." required></textarea>
            </div>
          </div>

          <!-- 6) ANEXOS -->
          <div class="card-form">
            <div class="section-head attach">
              <div>📎 Anexos</div>
              <small>Último bloco</small>
            </div>

            <div class="grid-2">
              <div>
                <label for="anexos">Escolher arquivos</label>
                <input type="file" id="anexos" name="anexos" multiple>
                <div class="field-hint">Os anexos serão tratados na próxima etapa.</div>
              </div>

              <div>
                <label>Resumo</label>
                <input type="text" value="Status inicial: Aberto" disabled>
              </div>
            </div>
          </div>

          <div class="acoes-form">
            <button type="submit" class="btn-primary">Salvar ocorrência</button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <%- include('partials/scripts') %>
</body>
</html>
